<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url><loc>{{ '/' | absolute_url }}</loc></url>
  <url><loc>{{ '/pages/areas/' | absolute_url }}</loc></url>
  <url><loc>{{ '/pages/carpet-cleaning/' | absolute_url }}</loc></url>
  <url><loc>{{ '/pages/upholstery-cleaning/' | absolute_url }}</loc></url>
  <url><loc>{{ '/pages/stain-removal/' | absolute_url }}</loc></url>
  <url><loc>{{ '/pages/rug-cleaning/' | absolute_url }}</loc></url>
  <url><loc>{{ '/pages/moth-treatment/' | absolute_url }}</loc></url>
  <url><loc>{{ '/pages/commercial/' | absolute_url }}</loc></url>
  <url><loc>{{ '/pages/reviews/' | absolute_url }}</loc></url>
  <url><loc>{{ '/pages/gallery/' | absolute_url }}</loc></url>
  <url><loc>{{ '/pages/get-a-quote/' | absolute_url }}</loc></url>
  {% for t in site.data.towns %}<url><loc>{{ '/areas/' | append: t.slug | append: '/' | absolute_url }}</loc></url>{% endfor %}
  {% for t in site.data.towns %}{% for s in site.data.services %}<url><loc>{{ '/locations/' | append: t.slug | append: '/' | append: s.slug | append: '/' | absolute_url }}</loc></url>{% endfor %}{% endfor %}
</urlset>
